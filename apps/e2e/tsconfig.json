{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["DOM", "ES2020"],
    "outDir": "./dist",
    "rootDir": ".",
    "sourceMap": true,
    "esModuleInterop": true,
    "noEmit": true
  },
  "include": ["src/**/*", "playwright.config.ts"],
  "exclude": ["node_modules", "dist", "test-results"]
}
